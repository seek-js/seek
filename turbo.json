{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "lint": {},
    "format:check": {},
    "format:fix": {
      "cache": false
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": ["tsconfig.tsbuildinfo", "packages/*/tsconfig.tsbuildinfo"]
    },
    "test": {
      "cache": false
    },
    "validate:metadata": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    }
  }
}
