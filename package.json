{
  "name": "seek",
  "private": true,
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "workspaces:list": "bun pm ls --all",
    "prepare": "husky",
    "precommit:check": "lint-staged",
    "commitmsg:check": "commitlint --edit",
    "build": "bun run --workspaces build",
    "typecheck": "tsc -b --pretty false --noEmit",
    "test": "bun test",
    "lint": "biome lint .",
    "format:check": "biome check .",
    "format:fix": "biome check . --write",
    "validate:metadata": "node ./scripts/validate-metadata.mjs",
    "check:metadata": "bun run build && bun run validate:metadata",
    "check": "bun run typecheck && bun run lint && bun run format:check && bun run test && bun run build && bun run validate:metadata"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx,jsx,json,md,yml,yaml}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "tsdown": "^0.21.9",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3"
  }
}
