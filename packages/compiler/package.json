{
  "name": "@seekjs/compiler",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "tsdown -c tsdown.config.mts src/index.ts --format esm --dts --out-dir dist",
    "typecheck": "tsc -b --pretty false --noEmit",
    "lint": "biome lint .",
    "format:check": "biome format .",
    "format:fix": "biome format . --write",
